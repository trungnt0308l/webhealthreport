# Auth0 configuration for the frontend (Vite)
# Copy to .env.local and fill in your Auth0 app values
#
# Note: AUTH0_DOMAIN and AUTH0_AUDIENCE for the backend (Workers Functions)
# are managed in wrangler.toml and deployed automatically via deploy.ps1.

VITE_AUTH0_DOMAIN=YOUR_TENANT.auth0.com
VITE_AUTH0_CLIENT_ID=YOUR_CLIENT_ID
VITE_AUTH0_AUDIENCE=https://YOUR_DOMAIN/api

# PayPal — public client ID from developer.paypal.com > Apps & Credentials
# Set this in Cloudflare Pages dashboard (Plaintext) for production builds
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id

# Cloudflare Turnstile — get keys at dash.cloudflare.com > Turnstile
# Leave unset in dev to use the built-in test key (always passes)
# VITE_TURNSTILE_SITE_KEY=your_site_key
